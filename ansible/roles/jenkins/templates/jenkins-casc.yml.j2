---
# =====================================================
# Jenkins Configuration as Code (JCasC)
# Template ini di-render oleh Ansible dan di-mount ke
# Jenkins container sebagai konfigurasi otomatis.
#
# Referensi: https://www.jenkins.io/projects/jcasc/
# =====================================================

jenkins:
  systemMessage: |
    ============================================================
    Jenkins CI/CD - Miniproject DevOps Kelompok 3
    Configured automatically by Ansible + JCasC
    ============================================================

  # Jumlah executor untuk concurrent builds
  numExecutors: {{ jenkins_num_executors }}

  # Mode: hanya menjalankan job yang di-assign ke master
  mode: NORMAL

  # CSRF Protection — mencegah Cross-Site Request Forgery
  crumbIssuer:
    standard: {}

  securityRealm:
    local:
      allowsSignup: false
      users:
        - id: "{{ jenkins_admin_user }}"
          password: "{{ jenkins_admin_password }}"

  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false

  remotingSecurity:
    enabled: true

  # Markup Formatter — Safe HTML rendering
  markupFormatter:
    rawHtml:
      disableSyntaxHighlighting: false

unclassified:
  location:
    url: "{{ jenkins_url }}"
    adminAddress: "{{ vault_smtp_username }}"

  gitSCM:
    globalConfigEmail: "{{ git_email }}"
    globalConfigName: "{{ git_name }}"

  # Konfigurasi Email Notification Standar
  mailer:
    smtpHost: "smtp.gmail.com"
    smtpPort: "587"
    useSsl: false
    useTls: true
    charset: "UTF-8"
    authentication:
      username: "{{ vault_smtp_username }}"
      password: "{{ vault_smtp_password }}"

# =====================================================
# Tool Configuration
# Install tools secara otomatis agar pipeline bisa jalan
# tanpa konfigurasi manual di Jenkins UI
# =====================================================
tool:
  git:
    installations:
      - name: "Default"
        home: "git"

  nodejs:
    installations:
      - name: "NodeJS-20"
        properties:
          - installSource:
              installers:
                - nodeJSInstaller:
                    id: "20.11.1"
                    npmPackagesRefreshHours: 72

# =====================================================
# Credentials — Managed via JCasC
# =====================================================
credentials:
  system:
    domainCredentials:
      - credentials:
          - usernamePassword:
              scope: GLOBAL
              id: "{{ dockerhub_creds_id }}"
              username: "{{ vault_dockerhub_username }}"
              password: "{{ vault_dockerhub_pat }}"
              description: "Docker Hub credentials for Jenkins pipelines"

          # SSH Credentials untuk Target Node Deployment
          - basicSSHUserPrivateKey:
              scope: GLOBAL
              id: "target-node-ssh"
              username: "ubuntu"
              description: "SSH key untuk deploy ke Target Node"
              privateKeySource:
                directEntry:
                  privateKey: "${TARGET_SSH_KEY}"

jobs:
  - script: |
      pipelineJob('{{ jenkins_job_name }}') {
        definition {
          cpsScm {
            scm {
              git {
                remote {
                  url('https://github.com/riskiyatul01/miniprojectdevops.git')
                }
                branches('*/main')
                extensions { } 
              }
            }
            scriptPath('Jenkinsfile')
          }
        }
        triggers {
          scm('* * * * *')
        }
      }